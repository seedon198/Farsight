# FARSIGHT reads API keys from environment variables (see farsight/config.py).
# Copy this file to .env and fill in the keys you have, then export them into
# your shell (e.g. `export $(grep -v '^#' .env | xargs)` or use direnv) --
# FARSIGHT does not auto-load a .env file itself.
#
# All keys are optional. FARSIGHT works with zero configuration; each key
# just unlocks deeper results from that provider.

FARSIGHT_SHODAN_API_KEY=
FARSIGHT_CENSYS_API_KEY=
FARSIGHT_SECURITYTRAILS_API_KEY=
FARSIGHT_VIRUSTOTAL_API_KEY=
FARSIGHT_INTELX_API_KEY=
FARSIGHT_LEAKPEEK_API_KEY=
# Crunchbase is paid/Enterprise-only (no free tier since ~2020). Only set
# this if you already have a key -- acquisition discovery still works
# without it via free Wikidata + news sources.
FARSIGHT_CRUNCHBASE_API_KEY=
