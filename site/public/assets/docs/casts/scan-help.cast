[0.729842, "o", "\u001b[2mв•­в”Ђ\u001b[0m\u001b[2m Arguments \u001b[0m\u001b[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\u001b[0m\u001b[2mв”Ђв•®\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[31m*\u001b[0m    domain      \u001b[1;33mTEXT\u001b[0m  Target domain to scan \u001b[2m[default: None]\u001b[0m \u001b[2;31m[required]\u001b[0m      \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї\u001b[0m\r\n"]
[0.740766, "o", "\u001b[2mв•­в”Ђ\u001b[0m\u001b[2m Options \u001b[0m\u001b[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\u001b[0m\u001b[2mв”Ђв•®\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-output\u001b[0m          \u001b[1;32m-o\u001b[0m      \u001b[1;33mPATH   \u001b[0m  Output file path \u001b[2m[default: report.md]\u001b[0m     \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-depth\u001b[0m           \u001b[1;32m-d\u001b[0m      \u001b[1;33mINTEGER\u001b[0m  Scan depth level (1-3) \u001b[2m[default: 1]\u001b[0m       \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-modules\u001b[0m         \u001b[1;32m-m\u001b[0m      \u001b[1;33mTEXT   \u001b[0m  Specific modules to run (org, recon,      \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m                                    threat, typosquat, news, attack_surface)  \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m                                    \u001b[2m[default: None]                          \u001b[0m \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-all\u001b[0m                     \u001b[1;33m       \u001b[0m  Run all available modules                 \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-news\u001b[0m                    \u001b[1;33m       \u001b[0m  Include news monitoring                   \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-typosquat\u001b[0m               \u001b[1;33m       \u001b[0m  Include typosquatting detection           \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-threat\u001b[0m\u001b[1;36m-intel\u001b[0m    \u001b[1;32m-t\u001b[0m      \u001b[1;33m       \u001b[0m  Include threat intelligence               \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-attack\u001b[0m\u001b[1;36m-surface\u001b[0m  \u001b[1;32m-a\u001b[0m      \u001b[1;33m       \u001b[0m  Include extended attack surface discovery \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m                                    (ASN/netblock/cloud/bucket search)        \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-verbose\u001b[0m         \u001b[1;32m-v\u001b[0m      \u001b[1;33m       \u001b[0m  Verbose output                            \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-timeout\u001b[0m                 \u001b[1;33mINTEGER\u001b[0m  Global timeout for requests in seconds    \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m                                    \u001b[2m[default: 30]                         \u001b[0m    \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-force\u001b[0m           \u001b[1;32m-f\u001b[0m      \u001b[1;33m       \u001b[0m  Force overwrite output file if exists     \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-concurrency\u001b[0m     \u001b[1;32m-c\u001b[0m      \u001b[1;33mINTEGER\u001b[0m  Maximum concurrent requests \u001b[2m[default: 10]\u001b[0m \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв”‚\u001b[0m \u001b[1;36m-\u001b[0m\u001b[1;36m-help\u001b[0m                    \u001b[1;33m       \u001b[0m  Show this message and exit.               \u001b[2mв”‚\u001b[0m\r\n\u001b[2mв•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї\u001b[0m\r\n"]
