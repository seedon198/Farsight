---
const talks = [
  {
    logo: '/assets/appsecvillage-logo.png',
    conference: 'DEFCON 34',
    venue: 'AppSec Village',
    date: 'Aug 6–9, 2026',
    location: 'Las Vegas',
    status: 'Upcoming',
    title: 'Farsight: Turning OSINT into Actionable Attack Surface Intelligence',
    href: 'https://www.appsecvillage.com/events/dc-2026/farsight-turning-osint-into-actionable-attack-surface-intelligence-1206456',
  },
  {
    logo: '/assets/blackhat-logo.png',
    conference: 'BLACKHAT 2025',
    venue: 'Arsenal',
    date: 'Oct 1–2, 2025',
    location: 'Toronto',
    status: 'Presented',
    title: 'Farsight: CLI-Based Recon and Threat Intelligence Framework',
    href: 'https://www.blackhat.com/sector/2025/arsenal/schedule/index.html#farsight-cli-based-recon-and-threat-intelligence-framework-47707',
  },
];
---
<section class="mx-auto max-w-5xl px-6 py-16 2xl:max-w-6xl">
  <h2 class="mb-10 text-center font-display text-2xl uppercase text-[var(--ink)]">Talks</h2>
  <div class="grid gap-6 sm:grid-cols-2">
    {talks.map((talk) => (
      <a
        href={talk.href}
        target="_blank"
        rel="noopener noreferrer"
        class="brutal-border brutal-shadow flex flex-col items-center gap-4 bg-[var(--surface)] p-6 text-center"
      >
        <img src={talk.logo} alt={`${talk.conference} logo`} class="h-16 w-auto" loading="lazy" />
        <div>
          <p class="font-display uppercase text-[var(--ink)]">{talk.conference} &middot; {talk.venue}</p>
          <p class="text-sm text-[var(--ink)]">{talk.date} &bull; {talk.location} &bull; {talk.status}</p>
        </div>
        <p class="text-sm text-[var(--ink)]">{talk.title}</p>
      </a>
    ))}
  </div>
</section>
