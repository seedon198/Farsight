---
const features = [
  {
    title: 'Organization Discovery',
    description: 'WHOIS, certificate transparency, passive DNS, related domains.',
  },
  {
    title: 'Recon & Asset Discovery',
    description: 'DNS enumeration, subdomain discovery, async port scanning.',
  },
  {
    title: 'Threat Intelligence',
    description: 'Leak detection, credential exposure, dark web mentions, email reputation.',
  },
  {
    title: 'Typosquatting Detection',
    description: 'Domain permutation, content similarity, risk scoring.',
  },
  {
    title: 'News Monitoring',
    description: 'Relevance-scored news tracking across multiple sources.',
  },
  {
    title: 'Reporting',
    description: 'Markdown and PDF output with executive summaries.',
  },
];
---
<section class="mx-auto max-w-5xl px-6 py-16">
  <h2 class="mb-10 text-center text-2xl font-semibold text-white">Features</h2>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {features.map((feature) => (
      <div class="rounded-lg border border-slate-800 bg-slate-900 p-6">
        <h3 class="mb-2 font-semibold text-emerald-300">{feature.title}</h3>
        <p class="text-sm text-slate-400">{feature.description}</p>
      </div>
    ))}
  </div>
</section>
