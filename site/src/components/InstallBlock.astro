---
const commands = [
  'git clone https://github.com/seedon198/Farsight.git',
  'cd Farsight',
  'python3 -m venv venv && source venv/bin/activate',
  'pip install -r requirements.txt',
  'python -m farsight scan example.com',
].join('\n');
---
<section id="install" class="mx-auto max-w-3xl px-6 py-16 2xl:max-w-4xl">
  <h2 class="mb-6 text-center font-display text-2xl uppercase text-[var(--ink)]">Zero to Scanning in 4 Commands</h2>
  <div class="brutal-border brutal-shadow relative bg-[var(--surface)]">
    <button
      type="button"
      data-copy-target="install-commands"
      class="surface-cta brutal-border absolute right-3 top-3 px-3 py-1 font-display text-xs uppercase"
    >
      Copy
    </button>
    <pre id="install-commands" class="overflow-x-auto p-6 pr-24 font-mono text-sm text-[var(--ink)]"><code>{commands}</code></pre>
  </div>
  <p class="mt-4 text-center text-sm text-[var(--ink)]">Requires Python 3.10+.</p>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy-target]').forEach((button) => {
    button.addEventListener('click', async () => {
      if (button.disabled) return;
      const targetId = button.dataset.copyTarget;
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (!target) return;
      const original = button.textContent;
      button.disabled = true;
      try {
        await navigator.clipboard.writeText(target.innerText);
        button.textContent = 'Copied!';
        await new Promise((resolve) => setTimeout(resolve, 2000));
      } catch {
        // clipboard write failed (denied permission or insecure context) — fall through to restore label
      } finally {
        button.textContent = original;
        button.disabled = false;
      }
    });
  });
</script>
