---
---
<section class="mx-auto max-w-4xl px-6 py-16 2xl:max-w-5xl">
  <h2 class="mb-8 text-center font-display text-2xl uppercase text-[var(--ink)]">See It In Action</h2>
  <div class="brutal-border brutal-shadow overflow-hidden bg-[var(--surface)]">
    <div class="flex items-center gap-2 border-b-[3px] border-[var(--ink)] bg-[var(--accent-primary)] px-4 py-3">
      <span class="h-3 w-3 rounded-full bg-white"></span>
      <span class="h-3 w-3 rounded-full bg-[var(--accent-cta)]"></span>
      <span class="h-3 w-3 rounded-full bg-white"></span>
    </div>
    <img src="/assets/demo.gif" alt="FARSIGHT demo: scanning a domain from the CLI" class="w-full" loading="lazy" />
  </div>

  <h3 class="mb-6 mt-14 text-center font-display text-lg uppercase text-[var(--ink)]">Web Dashboard</h3>
  <div class="flex flex-col gap-4">
    <img src="/assets/web-ui-scan.png" alt="FARSIGHT web UI: scan form with live stats" class="brutal-border brutal-shadow w-full" loading="lazy" />
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <img src="/assets/web-ui-graph.png" alt="FARSIGHT web UI: attack surface graph" class="brutal-border brutal-shadow w-full" loading="lazy" />
      <img src="/assets/web-ui-typosquat.png" alt="FARSIGHT web UI: typosquat watch grid" class="brutal-border brutal-shadow w-full" loading="lazy" />
    </div>
    <img src="/assets/web-ui-report.png" alt="FARSIGHT web UI: in-browser report" class="brutal-border brutal-shadow w-full" loading="lazy" />
  </div>
</section>
