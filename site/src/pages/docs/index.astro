---
import { getCollection, getEntry, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const entry = await getEntry('docs', 'getting-started');
if (!entry) {
  throw new Error('docs/getting-started.md is missing');
}
const { Content } = await render(entry);
const allEntries = await getCollection('docs');
---

<DocsLayout title={entry.data.title} description={entry.data.description} entries={allEntries} currentId={entry.id}>
  <Content />
</DocsLayout>
